{
  "targets": [
    "scripts",
    "app",
    ".github"
  ],
  "rules": [
    {
      "pattern": "https://astral\\.sh",
      "match_type": "regex",
      "description": "Bootstrapping the `uv` package manager."
    },
    {
      "pattern": "huggingface-hub",
      "match_type": "substring",
      "description": "Model acquisition (e.g., `facebook/opt-125m` for generative naming)."
    },
    {
      "pattern": "https://download\\.pytorch\\.org",
      "match_type": "regex",
      "description": "Fetching CPU-optimized PyTorch wheels."
    },
    {
      "pattern": "actions/checkout",
      "match_type": "substring",
      "description": "Fetching source code in CI."
    },
    {
      "pattern": "astral-sh/setup-uv",
      "match_type": "substring",
      "description": "Setting up uv in CI."
    }
  ]
}
